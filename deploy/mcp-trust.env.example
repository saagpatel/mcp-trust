# Copy to /etc/mcp-trust/mcp-trust.env on the VM.
# Keep this file free of secrets in the repository.

MCP_TRUST_DB=/data/mcp-trust/registry.db
MCP_TRUST_ENGINE=mcpaudit
MCP_TRUST_PUBLIC_READONLY=1

# Operator scan shells should set this, but the public read-only web service
# does not need receipt writes enabled.
# MCP_TRUST_RECEIPTS_DIR=/data/mcp-trust/receipts

# Never set this in public.
# MCP_TRUST_ALLOW_UNAUTHENTICATED_STUB_SCANS=1

# Only use for a private operator surface, not the public web service.
# MCP_TRUST_SCAN_TOKEN=
